# ===========================================================
# HUGGIING FACE variables (to start MLFLOW server from its internal online Docker container)
# ===========================================================
MLFLOW_TRACKING_URI=

# ===========================================================
# NEON-db variables (used by MLFLOW server to store database db files)
# ===========================================================
BACKEND_STORE_URI=

# ===========================================================
# AWS S3 variables (used by MLFLOW server to store metrics and artifacts)
# ===========================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ARTIFACT_ROOT=
