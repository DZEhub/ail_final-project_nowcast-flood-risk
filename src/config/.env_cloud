# ===========================================================
# AWS S3 variables (for ETL: for database storage to s3)
# ===========================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ARTIFACT_ROOT=
AWS_S3_DEFAULT_REGION="eu-west-3"
AWS_S3_PROFILE_NAME="default"


# ===========================================================
# AWS S3 buckets configuration
# ===========================================================

# depuis mes [Compartiments] >> [Compartiments à usage général] dans aws s3, on peut recuperper directement le noms de buckets existants, et les utiliser pour tester la connexion 
# et lister les fichiers qu'ils contiennent. On peut egalement aussi voir les fichiers qui s'y trouvent et leurs details (nom, taille, date de creation, etc...)
# Make sure that the s3 bucket you are using already exists in your s3, otherwise you will get an error when trying to upload files to it. 
# You can create a bucket from the aws s3 console or using boto3 resource with create_bucket() method.
EXISTING_BUCKET_MAIN="jedha-dz-dsft41"

# Main or root folder in your s3 bucket where to store the data, you can change it as you want
S3_RESOURCE_ROOT_FOLDER="Final_Project_Forecasting"


